{
  "name": "@rezafab/fab-button",
  "version": "1.5.3",
  "private": false,
  "description": "Styled by default. Flexible by design.",
  "keywords": [
    "button",
    "design-system",
    "ui",
    "typescript",
    "monorepo"
  ],
  "homepage": "https://github.com/RezaFab/fab-button#readme",
  "bugs": {
    "url": "https://github.com/RezaFab/fab-button/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RezaFab/fab-button.git"
  },
  "license": "MIT",
  "author": "Reza Lesmana",
  "type": "module",
  "main": "./packages/core/dist/index.cjs",
  "module": "./packages/core/dist/index.js",
  "types": "./packages/core/dist/index.d.ts",
  "files": [
    "README.md",
    "LICENSE",
    "packages/core/dist",
    "packages/react/dist",
    "packages/vue/dist",
    "packages/svelte/dist",
    "packages/element/dist",
    "packages/styles/style.css",
    "packages/theme-tokens/index.js",
    "packages/theme-tokens/index.d.ts",
    "packages/theme-tokens/tokens.css"
  ],
  "exports": {
    ".": {
      "types": "./packages/core/dist/index.d.ts",
      "import": "./packages/core/dist/index.js",
      "require": "./packages/core/dist/index.cjs"
    },
    "./core": {
      "types": "./packages/core/dist/index.d.ts",
      "import": "./packages/core/dist/index.js",
      "require": "./packages/core/dist/index.cjs"
    },
    "./react": {
      "types": "./packages/react/dist/index.d.ts",
      "import": "./packages/react/dist/index.js",
      "require": "./packages/react/dist/index.cjs"
    },
    "./react/style.css": "./packages/react/dist/fab-button-react.css",
    "./vue": {
      "types": "./packages/vue/dist/index.d.ts",
      "import": "./packages/vue/dist/index.js",
      "require": "./packages/vue/dist/index.cjs"
    },
    "./vue/style.css": "./packages/vue/dist/fab-button-vue.css",
    "./svelte": {
      "types": "./packages/svelte/dist/index.d.ts",
      "svelte": "./packages/svelte/dist/index.js",
      "import": "./packages/svelte/dist/index.js",
      "default": "./packages/svelte/dist/index.js"
    },
    "./svelte/style.css": "./packages/svelte/dist/fab-button-svelte.css",
    "./element": {
      "types": "./packages/element/dist/index.d.ts",
      "import": "./packages/element/dist/index.js",
      "require": "./packages/element/dist/index.cjs"
    },
    "./element/style.css": "./packages/element/dist/fab-button-element.css",
    "./styles.css": "./packages/styles/style.css",
    "./theme-tokens": {
      "types": "./packages/theme-tokens/index.d.ts",
      "import": "./packages/theme-tokens/index.js",
      "default": "./packages/theme-tokens/index.js"
    },
    "./theme-tokens/tokens.css": "./packages/theme-tokens/tokens.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @rezafab/docs storybook",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "storybook": "pnpm --filter @rezafab/docs storybook",
    "storybook:build": "pnpm --filter @rezafab/docs build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "version:major-button": "npm version major",
    "version:merge": "npm version minor",
    "version:fix": "npm version patch",
    "release": "pnpm build && pnpm run release:version",
    "release:version": "changeset version && pnpm install",
    "release:publish": "pnpm -r publish --access public && pnpm publish --access public"
  },
  "dependencies": {
    "@rezafab/fab-button-theme-tokens": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^8.6.18",
    "typescript": "^6.0.3",
    "vite": "^6.4.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.18.3",
  "publishConfig": {
    "access": "public"
  }
}
