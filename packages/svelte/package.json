      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "dependencies": {
    "@rezafab/fab-button-core": "workspace:*",
    "@rezafab/fab-button-styles": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "svelte": "^5.43.2",
    "typescript": "^6.0.3",
    "vite": "^6.4.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
